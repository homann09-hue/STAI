STOCKPILOT_CRYPTO_QUOTE_CACHE_TTL_MS=3000
STOCKPILOT_STALE_QUOTE_CACHE_TTL_MS=300000
STOCKPILOT_RATE_LIMIT_BACKOFF_MS=60000
