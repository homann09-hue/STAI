UPSTASH_REDIS_REST_TOKEN=

# Cost controls for API routes and live polling.
STOCKPILOT_QUOTES_TTL_MS=8000
STOCKPILOT_QUOTES_STALE_TTL_MS=90000
STOCKPILOT_STREAM_INTERVAL_MS=15000
STOCKPILOT_STREAM_MIN_INTERVAL_MS=5000
STOCKPILOT_STREAM_MAX_INTERVAL_MS=60000
